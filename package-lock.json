{
    "name": "carniceria-pos",
    "version": "1.0.0",
    "lockfileVersion": 3,
    "requires": true,
    "packages": {
        "": {
            "name": "carniceria-pos",
            "version": "1.0.0",
            "workspaces": [
                "packages/*",
                "services/backend",
                "apps/frontend",
                "apps/desktop"
            ]
        },
        "apps/desktop": {
            "name": "@carniceria/desktop",
            "version": "1.0.0"
        },
        "apps/frontend": {
            "name": "@carniceria/frontend",
            "version": "1.0.0"
        },
        "node_modules/@carniceria/backend": {
            "resolved": "services/backend",
            "link": true
        },
        "node_modules/@carniceria/desktop": {
            "resolved": "apps/desktop",
            "link": true
        },
        "node_modules/@carniceria/frontend": {
            "resolved": "apps/frontend",
            "link": true
        },
        "node_modules/@carniceria/shared": {
            "resolved": "packages/shared",
            "link": true
        },
        "packages/shared": {
            "name": "@carniceria/shared",
            "version": "1.0.0"
        },
        "services/backend": {
            "name": "@carniceria/backend",
            "version": "1.0.0"
        }
    }
}
